# Copy file này thành .env rồi đổi hết các giá trị CHANGE_ME.
# .env nằm trong .gitignore — không bao giờ commit.

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=hs
# openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hackathon

# Phải khớp với 3 biến trên.
# Trên VPS (chạy bằng docker compose) host là tên service `db`:
DATABASE_URL="postgresql://hs:CHANGE_ME@db:5432/hackathon?schema=public"
# Chạy `npm run dev` ở máy local thì đổi host thành localhost:
# DATABASE_URL="postgresql://hs:hs@localhost:5432/hackathon?schema=public"

# ── App ─────────────────────────────────────────────────────────────────
# openssl rand -hex 32
# Đổi giá trị này sẽ vô hiệu toàn bộ phiên đăng nhập đang mở — đừng đổi giữa buổi chấm.
SESSION_SECRET="CHANGE_ME_ITNHAT_32_KY_TU"

# ── Mã truy cập ─────────────────────────────────────────────────────────
# Chỉ được đọc lúc chạy seed lần đầu. Sau đó quản lý mã trong trang Admin.
# Mã mặc định trong prisma/seed.ts nằm công khai trong repo — bắt buộc đổi.
ADMIN_ACCESS_CODE="CHANGE-ME-ADMIN"
HEAD_ACCESS_CODE="CHANGE-ME-HEAD"
JUDGE_ACCESS_CODES="CHANGE-ME-BGK2,CHANGE-ME-BGK3,CHANGE-ME-BGK4,CHANGE-ME-BGK5"

# Seed có tạo kèm điểm mẫu không. Mặc định: có ở dev, không ở production.
# SEED_SCORES=0
